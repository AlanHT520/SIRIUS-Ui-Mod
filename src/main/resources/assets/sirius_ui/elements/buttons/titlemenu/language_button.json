{
  "type": "button",
  "variables": {
    "button_label": "",
    "text_color": "16777088"
  },
  "ing_duration": 5,
  "texture": {
    "normal": "sirius_ui:buttons/titlemenu/language_button",
    "highlighted": "sirius_ui:buttons/titlemenu/language_button_highlighted",
    "disabled": "sirius_ui:buttons/titlemenu/language_button_disabled",
    "ing": "sirius_ui:buttons/titlemenu/language_button_ing"
  },
  "children": [
    {
      "type": "text",
      "text_key": "${button_label}",
      "color": "${text_color}",
      "position": {
        "x": "parent.width / 2 - this.width / 2",
        "y": "parent.height / 2 - this.height / 2"
      },
      "shadow": true
    }
  ]
}