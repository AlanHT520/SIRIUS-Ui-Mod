{
  "type": "list",
  "gap": 5,
  "background_color": "0x50000000",
  "member": {
    "label_w": "parent.width * 7 / 18",
    "label_x": "parent.width / 9",
    "control_w": "parent.width * 7 / 18",
    "control_x": "parent.width / 2",
    "elem_w": "parent.width * 7 / 9",
    "elem_x": "parent.width / 9"
  },
  "scrollbar": {
    "width": 4, "x": "parent.width - 4", "track": { "color": "0x00000000" }, "thumb": { "color": "0x44FFFFFF" }
  },
  "rows": [
    { "height": 5, "children": [] },
    { "height": 22, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.fov" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/slider/slider_fov.json", "filter_key": "options.fov", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 22, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.difficulty" }, "condition": "game.in_level", "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/arrow_switch/general/difficult_cycle.json", "filter_key": "options.difficulty", "text": {}, "condition": "game.in_level", "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 22, "children": [
      { "type": "button", "text_key": "options.language", "position": { "x": "this.elem_x" }, "size": { "width": "(this.elem_w - 5) / 2", "height": 20 },
        "texture": {
          "normal": "sirius_ui:buttons/default_button",
          "highlighted": "sirius_ui:buttons/default_button_highlighted",
          "disabled": "sirius_ui:buttons/default_button_disabled"
        },
        "action": { "type": "open_screen", "screenId": "language" }
      },
      { "type": "button", "text_key": "Mods", "position": { "x": "this.elem_x + (this.elem_w - 5) / 2 + 5" }, "size": { "width": "(this.elem_w - 5) / 2", "height": 20 },
        "texture": {
          "normal": "sirius_ui:buttons/default_button",
          "highlighted": "sirius_ui:buttons/default_button_highlighted",
          "disabled": "sirius_ui:buttons/default_button_disabled"
        },
        "action": { "type": "open_screen", "screenId": "mods_list" }
      }
    ]},
    { "height": 5, "children": [] },
    { "height": 22, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.realmsNotifications" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/arrow_switch/general/realms_notifications.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 22, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.allowServerListing" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/arrow_switch/general/allow_server_listing.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 22, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.telemetry.button" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/arrow_switch/general/telemetry.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]}
  ]
}