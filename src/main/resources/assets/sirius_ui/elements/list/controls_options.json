{
  "type": "list",
  "gap": 5,
  "background_color": "0x50000000",
  "member": {
    "label_w": "parent.width * 7 / 18",
    "label_x": "parent.width / 9",
    "control_w": "parent.width * 7 / 18",
    "control_x": "parent.width / 2",
    "elem_w": "parent.width * 7 / 9",
    "elem_x": "parent.width / 9"
  },
  "scrollbar": { "width": 4, "x": "parent.width - 4", "track": { "color": "0x00000000" }, "thumb": { "color": "0x44FFFFFF" } },
  "rows": [
    { "height": 5, "children": [] },
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.sensitivity" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/slider/controls/mouse_sensitivity.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.mouseWheelSensitivity" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/slider/controls/mouse_wheel_sensitivity.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.invertMouse" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/invert_y_mouse.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.discrete_mouse_scroll" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/discrete_mouse_scroll.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.touchscreen" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/touchscreen.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.rawMouseInput" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/raw_mouse_input.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "button", "text_key": "controls.keybinds", "position": { "x": "this.elem_x" }, "size": { "width": "this.elem_w", "height": 20 },
        "texture": {
          "normal": "sirius_ui:buttons/default_button",
          "highlighted": "sirius_ui:buttons/default_button_highlighted",
          "disabled": "sirius_ui:buttons/default_button_disabled"
        },
        "action": { "type": "open_screen", "screenId": "keybinds" }
      }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "key.sneak" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/toggle_crouch.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "key.sprint" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/toggle_sprint.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.autoJump" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/auto_jump.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]},
    { "height": 20, "children": [
      { "type": "text", "color": "0x00000000", "text": { "text_key": "options.operatorItemsTab" }, "position": { "x": "parent.width / 9 + 2", "y": "parent.height / 2 - this.height / 2" }, "size": { "width": "this.label_w", "height": 20 } },
      { "ref": "sirius_ui:elements/buttons/selector/controls/operator_items_tab.json", "text": {}, "position": { "x": "this.control_x" }, "size": { "width": "this.control_w", "height": 20 } }
    ]}
  ]
}