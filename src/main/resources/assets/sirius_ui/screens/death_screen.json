{
  "screen": {
    "parent": "sirius_ui:screens/screen.json",
    "graphicsDraw": [
      {
        "comment": "半透明深黑色全屏背景",
        "x": "0",
        "y": "0",
        "width": "screen.width",
        "height": "screen.height",
        "color": "0x88000000"
      },
      {
        "comment": "红色分隔线",
        "x": "screen.width/2 - 140",
        "y": "screen.height/2",
        "width": 280,
        "height": 1,
        "color": "0x88FF0000"
      }
    ],
    "elements": [
      {
        "type": "text",
        "text_key": "deathScreen.title",
        "position": { "x": "screen.width/2 - this.width/2", "y": "screen.height/5" },
        "color": "0x99FF0000",
        "shadow": true,
        "scale": 2.5
      },


      {
        "type": "text",
        "dynamicType": "death_cause",
        "position": { "x": "screen.width/2 - 140", "y": "screen.height/2 - 30" },
        "color": "0xFFFFFFFF",
        "shadow": true,
        "scale": 1.0
      },

      {
        "type": "text",
        "text_key.d": "deathScreen.score.value",
        "position": { "x": "screen.width/2 + 120", "y": "screen.height/2 - 30" },
        "color": "0xFFFFFFAA",
        "shadow": true
      },


      {
        "ref": "sirius_ui:elements/buttons/death/button_re.json",
        "position": { "x": "screen.width/2 - 130", "y": "screen.height * 3 / 4" },
        "size": { "width": 120, "height": 20 },
        "action": { "type": "respawn" }
      },
      {
        "ref": "sirius_ui:elements/buttons/death/button_quit.json",
        "position": { "x": "screen.width/2 + 10", "y": "screen.height * 3 / 4" },
        "size": { "width": 120, "height": 20 },
        "action": { "type": "exit_to_title" }
      }
    ]
  }
}